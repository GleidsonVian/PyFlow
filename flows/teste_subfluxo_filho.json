{
  "flow_name": "teste_subfluxo_filho",
  "created_at": "2026-05-02T00:00:00",
  "steps": [
    {
      "block": "OpenBrowserBlock",
      "params": { "url": "https://books.toscrape.com", "maximized": false }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "2" }
    },
    {
      "block": "ExtractTextBlock",
      "params": {
        "selector": "h1",
        "variable_name": "titulo_subfluxo",
        "timeout": "10"
      }
    },
    {
      "block": "ExtractTextBlock",
      "params": {
        "selector": ".page-header p",
        "variable_name": "total_livros",
        "timeout": "10"
      }
    }
  ]
}
