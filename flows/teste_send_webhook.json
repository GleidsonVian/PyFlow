{
  "flow_name": "Teste — Enviar para Webhook",
  "created_at": "2026-05-06",
  "steps": [
    {
      "block": "SetVariableBlock",
      "params": {
        "variable_name": "produto",
        "operation": "set",
        "value": "Notebook Dell XPS",
        "nota": "1. Cria variável de teste"
      }
    },
    {
      "block": "SetVariableBlock",
      "params": {
        "variable_name": "preco",
        "operation": "set",
        "value": "4999.90",
        "nota": "2. Cria segunda variável"
      }
    },
    {
      "block": "SendWebhookBlock",
      "params": {
        "url": "https://webhook.site/SEU-TOKEN-AQUI",
        "payload": "{\"produto\": \"{{produto}}\", \"preco\": \"{{preco}}\", \"origem\": \"PyFlow RPA\", \"timestamp\": \"agora\"}",
        "headers": "",
        "variable_name": "webhook_resposta",
        "timeout": "15",
        "nota": "3. Envia os dados para o webhook — troque a URL pelo seu token do webhook.site"
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "message": "Webhook enviado!\nResposta: {{webhook_resposta}}",
        "nota": "4. Mostra o resultado"
      }
    }
  ]
}
