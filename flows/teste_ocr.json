{
  "flow_name": "teste_ocr",
  "created_at": "2026-04-30T07:00:00.000000",
  "steps": [
    {
      "block": "OpenBrowserBlock",
      "params": { "url": "https://books.toscrape.com", "maximized": false }
    },
    {
      "block": "SmartWaitBlock",
      "params": { "condition": "page_loaded", "selector": "", "value": "", "timeout": "10", "poll_interval": "0.5", "variable_name": "" }
    },
    {
      "block": "OcrBlock",
      "params": {
        "source": "browser",
        "filepath": "",
        "language": "eng",
        "psm": "3",
        "preprocess": "grayscale",
        "crop": "",
        "variable_name": "ocr_pagina_completa",
        "save_image": false
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "OCR — Página completa",
        "message": "Palavras encontradas: {{ocr_pagina_completa_palavras}}\nLinhas: {{ocr_pagina_completa_linhas}}\n\nPrimeiros caracteres:\n{{ocr_pagina_completa}}",
        "kind": "info"
      }
    },
    {
      "block": "ScreenshotBlock",
      "params": { "filename": "para_ocr", "folder": "screenshots" }
    },
    {
      "block": "OcrBlock",
      "params": {
        "source": "file",
        "filepath": "screenshots/para_ocr.png",
        "language": "eng",
        "psm": "6",
        "preprocess": "threshold",
        "crop": "",
        "variable_name": "ocr_arquivo",
        "save_image": true
      }
    },
    {
      "block": "OcrBlock",
      "params": {
        "source": "browser",
        "filepath": "",
        "language": "eng",
        "psm": "7",
        "preprocess": "grayscale",
        "crop": "0,0,400,80",
        "variable_name": "ocr_header",
        "save_image": false
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "OCR — Recorte do header",
        "message": "Texto no header (recorte 400x80):\n{{ocr_header}}\n\nPalavras: {{ocr_header_palavras}}",
        "kind": "info"
      }
    },
    {
      "block": "SaveTextBlock",
      "params": {
        "content": "=== OCR Página Completa ===\n{{ocr_pagina_completa}}\n\n=== OCR Header ===\n{{ocr_header}}",
        "filepath": "saida/resultado_ocr.txt",
        "mode": "overwrite",
        "add_timestamp": true
      }
    },
    {
      "block": "CloseBrowserBlock",
      "params": {}
    },
    {
      "block": "DesktopNotificationBlock",
      "params": {
        "title": "✅ OCR concluído",
        "message": "{{ocr_pagina_completa_palavras}} palavras extraídas. Resultado salvo!",
        "duration": "6000"
      }
    }
  ]
}
