{
  "flow_name": "teste_extract_list",
  "created_at": "2026-04-30T00:10:00.000000",
  "steps": [
    {
      "block": "OpenBrowserBlock",
      "params": { "url": "https://books.toscrape.com", "maximized": false }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "2" }
    },
    {
      "block": "ExtractListBlock",
      "params": {
        "selector": ".product_pod h3 a",
        "attribute": "",
        "variable_name": "titulos_livros",
        "limit": "10",
        "filter_empty": true,
        "timeout": "10"
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "Lista extraída!",
        "message": "Total de livros: {{titulos_livros_total}}\nPrimeiro: {{titulos_livros_primeiro}}",
        "kind": "info"
      }
    },
    {
      "block": "ForEachBlock",
      "params": {
        "items": "titulos_livros",
        "variable_name": "titulo",
        "blocks_count": "1",
        "delay_between": "0"
      }
    },
    {
      "block": "SaveCsvBlock",
      "params": {
        "filepath": "saida/livros_extraidos.csv",
        "values": "{{titulo}}",
        "headers": "Titulo",
        "delimiter": ",",
        "add_timestamp": false
      }
    },
    {
      "block": "CloseBrowserBlock",
      "params": {}
    }
  ]
}
