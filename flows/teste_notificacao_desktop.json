{
  "flow_name": "teste_notificacao_desktop",
  "created_at": "2026-04-29T23:30:00.000000",
  "steps": [
    {
      "block": "OpenBrowserBlock",
      "params": {
        "url": "https://books.toscrape.com",
        "maximized": false
      }
    },
    {
      "block": "WaitBlock",
      "params": {
        "seconds": "2"
      }
    },
    {
      "block": "ExtractTextBlock",
      "params": {
        "selector": "h1",
        "variable_name": "titulo_pagina",
        "timeout": "10"
      }
    },
    {
      "block": "DesktopNotificationBlock",
      "params": {
        "title": "✅ PyFlow RPA — Coleta concluída",
        "message": "Página carregada: {{titulo_pagina}}",
        "duration": "6"
      }
    }
  ]
}
