  "steps": [
    {
      "block": "SQLiteBlock",
      "params": {
        "database": "dados/teste.db",
        "query": "CREATE TABLE IF NOT EXISTS produtos (id INTEGER PRIMARY KEY AUTOINCREMENT, nome TEXT, preco REAL, data TEXT)",
        "params": "",
        "variable_name": "db_resultado",
        "row_variable": ""
      }
    },
    {
      "block": "SetVariableBlock",
      "params": {
        "variable_name": "data_hoje",
        "operation": "now",
        "value": "",
        "format": "%d/%m/%Y"
      }
    },
    {
      "block": "SQLiteBlock",
      "params": {
        "database": "dados/teste.db",
        "query": "INSERT INTO produtos (nome, preco, data) VALUES (?, ?, ?)",
        "params": "PyFlow RPA|299.90|{{data_hoje}}",
        "variable_name": "",
        "row_variable": ""
      }
    },
    {
      "block": "SQLiteBlock",
      "params": {
        "database": "dados/teste.db",
        "query": "INSERT INTO produtos (nome, preco, data) VALUES (?, ?, ?)",
        "params": "Selenium Pro|149.50|{{data_hoje}}",
        "variable_name": "",
        "row_variable": ""
      }
    },
    {
      "block": "SQLiteBlock",
      "params": {
        "database": "dados/teste.db",
        "query": "SELECT * FROM produtos ORDER BY preco DESC",
        "params": "",
        "variable_name": "lista_produtos",
        "row_variable": "produto_caro"
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "Resultado do Banco",
        "message": "Total de produtos: {{lista_produtos_total}}\nMais caro: {{produto_caro_nome}}\nPreço: {{produto_caro_preco}}",
        "kind": "info"
      }
    },
    {
      "block": "SQLiteBlock",
      "params": {
        "database": "dados/teste.db",
        "query": "UPDATE produtos SET preco = ? WHERE nome = ?",
        "params": "199.90|PyFlow RPA",
        "variable_name": "",
        "row_variable": ""
      }
    },
    {
      "block": "SQLiteBlock",
      "params": {
        "database": "dados/teste.db",
        "query": "SELECT nome, preco FROM produtos WHERE preco < ?",
        "params": "250",
        "variable_name": "produtos_baratos",
        "row_variable": ""
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "Após UPDATE",
        "message": "Produtos abaixo de R$250:\n{{produtos_baratos}}",
        "kind": "info"
      }
    },
    {
      "block": "SaveCsvBlock",
      "params": {
        "filepath": "saida/produtos_db.csv",
        "values": "{{produto_caro_nome}}|{{produto_caro_preco}}|{{data_hoje}}",
        "headers": "Nome|Preco|Data",
        "delimiter": ",",
        "add_timestamp": false
      }
    },
    {
      "block": "DesktopNotificationBlock",
      "params": {
        "title": "✅ SQLite OK",
        "message": "{{lista_produtos_total}} produtos no banco. CSV exportado!",
