{
  "flow_name": "Automação Estilo n8n",
  "steps": [
    {
      "block": "TimerTriggerBlock",
      "params": {
        "frequency": "hourly",
        "value": "1",
        "active": true,
        "nota": "Gatilho de início"
      }
    },
    {
      "block": "HttpRequestBlock",
      "params": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/todos/1",
        "variable_name": "todo_data",
        "json_field": "title",
        "nota": "Busca um dado de teste estável"
      }
    },
    {
      "block": "PythonScriptBlock",
      "params": {
        "code": "titulo = var.get('todo_data', '')\n# Transforma o título para maiúsculas e conta palavras\nvar['titulo_formatado'] = titulo.upper()\nvar['total_palavras'] = len(titulo.split())\n\nprint(f\"Processado: {var['titulo_formatado']}\")",
        "nota": "Manipulação de string via Python"
      }
    },
    {
      "block": "DesktopNotificationBlock",
      "params": {
        "title": "PyFlow n8n Style",
        "message": "Título: {{titulo_formatado}}\nPalavras: {{total_palavras}}",
        "duration": "5000",
        "nota": "Notificação final"
      }
    }
  ]
}