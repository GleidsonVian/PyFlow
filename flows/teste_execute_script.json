    {
      "block": "ExecuteScriptBlock",
      "params": {
        "script": "return document.title;",
        "selector": "",
        "variable_name": "titulo_js"
      }
    },
    {
      "block": "ExecuteScriptBlock",
      "params": {
        "script": "return document.querySelectorAll('.product_pod').length;",
        "selector": "",
        "variable_name": "total_produtos"
      }
    },
    {
      "block": "ExecuteScriptBlock",
      "params": {
        "script": "window.scrollTo(0, document.body.scrollHeight);",
        "selector": "",
        "variable_name": ""
      }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "1" }
    },
    {
      "block": "ExecuteScriptBlock",
      "params": {
        "script": "arguments[0].scrollIntoView({behavior: 'smooth', block: 'center'});",
        "selector": "footer",
        "variable_name": ""
      }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "1" }
    },
    {
      "block": "ExecuteScriptBlock",
      "params": {
        "script": "arguments[0].style.border = '3px solid red'; return arguments[0].innerText;",
        "selector": ".product_pod:first-child h3 a",
        "variable_name": "primeiro_titulo_js"
      }
    },
    {
      "block": "ExecuteScriptBlock",
      "params": {
        "script": "return { url: window.location.href, largura: window.innerWidth, altura: window.innerHeight };",
        "selector": "",
        "variable_name": "info_pagina"
