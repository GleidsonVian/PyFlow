{
  "flow_name": "teste_hash",
  "created_at": "2026-04-30T11:00:00.000000",
  "steps": [
    {
      "block": "SetVariableBlock",
      "params": {
        "variable_name": "texto_base",
        "operation": "set",
        "value": "PyFlow RPA 2026",
        "format": ""
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "md5",
        "input_value": "{{texto_base}}",
        "secret_key": "",
        "encoding": "utf-8",
        "uppercase": false,
        "variable_name": "hash_md5"
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "sha256",
        "input_value": "{{texto_base}}",
        "secret_key": "",
        "encoding": "utf-8",
        "uppercase": false,
        "variable_name": "hash_sha256"
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "sha512",
        "input_value": "{{texto_base}}",
        "secret_key": "",
        "encoding": "utf-8",
        "uppercase": true,
        "variable_name": "hash_sha512"
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "base64_encode",
        "input_value": "{{texto_base}}",
        "secret_key": "",
        "encoding": "utf-8",
        "uppercase": false,
        "variable_name": "b64_encoded"
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "base64_decode",
        "input_value": "{{b64_encoded}}",
        "secret_key": "",
        "encoding": "utf-8",
        "uppercase": false,
        "variable_name": "b64_decoded"
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "url_encode",
        "input_value": "https://exemplo.com/busca?q=PyFlow RPA&cat=automação",
        "secret_key": "",
        "encoding": "utf-8",
        "uppercase": false,
        "variable_name": "url_encoded"
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "url_decode",
        "input_value": "{{url_encoded}}",
        "secret_key": "",
        "encoding": "utf-8",
        "uppercase": false,
        "variable_name": "url_decoded"
      }
    },
    {
      "block": "HashBlock",
      "params": {
        "operation": "hmac_sha256",
        "input_value": "{{texto_base}}",
        "secret_key": "minha-chave-secreta",
        "encoding": "utf-8",
        "uppercase": false,
        "variable_name": "hmac_resultado"
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "Hash / Criptografia OK",
        "message": "Texto: {{texto_base}}\n\nMD5: {{hash_md5}}\nSHA256: {{hash_sha256}}\n\nBase64: {{b64_encoded}}\nDecodificado: {{b64_decoded}}\n\nURL encoded: {{url_encoded}}\nURL decoded: {{url_decoded}}\n\nHMAC-SHA256: {{hmac_resultado}}",
        "kind": "info"
      }
    },
    {
      "block": "SaveTextBlock",
      "params": {
        "content": "=== HASHES DE: {{texto_base}} ===\nMD5:    {{hash_md5}}\nSHA256: {{hash_sha256}}\nSHA512: {{hash_sha512}}\nHMAC:   {{hmac_resultado}}\n\nBase64: {{b64_encoded}}\nURL:    {{url_encoded}}",
        "filepath": "saida/resultado_hash.txt",
        "mode": "overwrite",
        "add_timestamp": true
      }
    }
  ]
}
