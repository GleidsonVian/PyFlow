{
  "flow_name": "template_scraping_lista",
  "created_at": "2026-04-30T00:00:00",
  "description": "Extrai títulos, preços e links de uma página de listagem e salva em CSV.",
  "template": true,
  "steps": [
    {
      "block": "OpenBrowserBlock",
      "params": { "url": "https://books.toscrape.com", "maximized": false }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "2" }
    },
    {
      "block": "ExtractListBlock",
      "params": {
        "selector": ".product_pod h3 a",
        "attribute": "",
        "variable_name": "titulos",
        "limit": "20",
        "filter_empty": true,
        "timeout": "10"
      }
    },
    {
      "block": "ExtractListBlock",
      "params": {
        "selector": ".product_pod .price_color",
        "attribute": "",
        "variable_name": "precos",
        "limit": "20",
        "filter_empty": true,
        "timeout": "10"
      }
    },
    {
      "block": "ExtractListBlock",
      "params": {
        "selector": ".product_pod h3 a",
        "attribute": "href",
        "variable_name": "links",
        "limit": "20",
        "filter_empty": true,
        "timeout": "10"
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "Dados extraídos",
        "message": "Itens encontrados: {{titulos_total}}\nPrimeiro: {{titulos_primeiro}}\nPreço: {{precos_primeiro}}",
        "kind": "info"
      }
    },
    {
      "block": "ForEachBlock",
      "params": {
        "items": "titulos",
        "variable_name": "titulo",
        "blocks_count": "1",
        "delay_between": "0"
      }
    },
    {
      "block": "SaveCsvBlock",
      "params": {
        "filepath": "saida/scraping_lista.csv",
        "values": "{{titulo}}",
        "headers": "Titulo",
        "delimiter": ",",
        "add_timestamp": false
      }
    },
    {
      "block": "CloseBrowserBlock",
      "params": {}
    },
    {
      "block": "DesktopNotificationBlock",
      "params": {
        "title": "✅ Scraping concluído",
        "message": "{{titulos_total}} itens salvos em saida/scraping_lista.csv",
        "duration": "6000"
      }
    }
  ]
}
