{
  "flow_name": "template_preencher_formulario",
  "created_at": "2026-04-30T00:00:00",
  "description": "Lê uma lista de dados de um CSV e submete cada linha em um formulário.",
  "template": true,
  "steps": [
    {
      "block": "ReadCsvBlock",
      "params": {
        "filepath": "dados/contatos.csv",
        "column": "nome",
        "variable_name": "lista_nomes",
        "skip_header": true,
        "delimiter": ","
      }
    },
    {
      "block": "OpenBrowserBlock",
      "params": { "url": "https://httpbin.org/forms/post", "maximized": false }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "2" }
    },
    {
      "block": "ForEachBlock",
      "params": {
        "items": "lista_nomes",
        "variable_name": "nome_atual",
        "blocks_count": "5",
        "delay_between": "1"
      }
    },
    {
      "block": "FillFieldBlock",
      "params": {
        "selector": "input[name='custname']",
        "value": "{{nome_atual}}",
        "clear_before": true,
        "timeout": "10"
      }
    },
    {
      "block": "FillFieldBlock",
      "params": {
        "selector": "input[name='custtel']",
        "value": "11999999999",
        "clear_before": true,
        "timeout": "10"
      }
    },
    {
      "block": "ClickElementBlock",
      "params": { "selector": "input[type='submit']", "timeout": "10" }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "1" }
    },
    {
      "block": "SaveTextBlock",
      "params": {
        "content": "Formulário enviado para: {{nome_atual}}",
        "filepath": "saida/formularios_enviados.txt",
        "mode": "append",
        "add_timestamp": true
      }
    },
    {
      "block": "NavigateToUrlBlock",
      "params": { "url": "https://httpbin.org/forms/post" }
    },
    {
      "block": "CloseBrowserBlock",
      "params": {}
    },
    {
      "block": "DesktopNotificationBlock",
      "params": {
        "title": "✅ Formulários enviados",
        "message": "{{lista_nomes_total}} formulários preenchidos com sucesso!",
        "duration": "7000"
      }
    }
  ]
}
