{
  "flow_name": "teste_mouse_actions",
  "created_at": "2026-04-30T00:30:00.000000",
  "steps": [
    {
      "block": "OpenBrowserBlock",
      "params": { "url": "https://books.toscrape.com", "maximized": false }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "2" }
    },
    {
      "block": "MouseActionBlock",
      "params": {
        "action": "hover",
        "selector": ".product_pod h3 a",
        "target_selector": "",
        "offset_x": "0",
        "offset_y": "0",
        "timeout": "10"
      }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "1" }
    },
    {
      "block": "MouseActionBlock",
      "params": {
        "action": "double_click",
        "selector": ".product_pod h3 a",
        "target_selector": "",
        "offset_x": "0",
        "offset_y": "0",
        "timeout": "10"
      }
    },
    {
      "block": "WaitBlock",
      "params": { "seconds": "2" }
    },
    {
      "block": "ExtractTextBlock",
      "params": {
        "selector": "h1",
        "variable_name": "titulo_produto",
        "timeout": "10"
      }
    },
    {
      "block": "ShowMessageBlock",
      "params": {
        "title": "Mouse Actions OK",
        "message": "Hover e duplo clique funcionaram!\nPágina atual: {{titulo_produto}}",
        "kind": "info"
      }
    },
    {
      "block": "CloseBrowserBlock",
      "params": {}
    }
  ]
}
