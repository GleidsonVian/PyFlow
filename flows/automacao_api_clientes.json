{
  "steps": [
    {
      "block": "HttpRequestBlock",
      "params": { "url": "https://jsonplaceholder.typicode.com/users", "method": "GET", "variable_name": "usuarios" },
      "_id": "api1",
      "_x": 50, "_y": 150,
      "_next_success": "loop1"
    },
    {
      "block": "ForEachBlock",
      "params": { "variable_name": "item", "list_variable": "usuarios" },
      "_id": "loop1",
      "_x": 280, "_y": 150,
      "_next_success": "if1"
    },
    {
      "block": "IfBlock",
      "params": { "condition": "'Suite' in '{{item.address.suite}}'" },
      "_id": "if1",
      "_x": 510, "_y": 150,
      "_next_success": "msg1",
      "_next_error": "endif1"
    },
    {
      "block": "ShowMessageBlock",
      "params": { "title": "Filtro de Endereço", "message": "O usuário {{item.name}} mora em uma Suite: {{item.address.suite}}", "type": "info" },
      "_id": "msg1",
      "_x": 740, "_y": 50,
      "_next_success": "endif1"
    },
    {
      "block": "EndIfBlock",
      "params": {},
      "_id": "endif1",
      "_x": 970, "_y": 150,
      "_next_success": "loop_end"
    },
    {
      "block": "EndForEachBlock",
      "params": {},
      "_id": "loop_end",
      "_x": 1200, "_y": 150
    }
  ]
}
